{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmad-code-org/schemas/capsule.json",
  "title": "Handoff Capsule",
  "description": "Canonical handoff item generated by design-system and consumed by execute.",
  "type": "object",
  "additionalProperties": false,
  "required": ["capsuleId", "kind", "title", "summary", "sourceCommand", "priority"],
  "properties": {
    "capsuleId": {
      "type": "string",
      "minLength": 3,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "description": "Deterministic id (kebab-case)."
    },
    "kind": {
      "type": "string",
      "enum": ["design-system-choice", "design-token", "component-guideline", "accessibility-requirement", "implementation-constraint"]
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "summary": {
      "type": "string",
      "minLength": 8
    },
    "sourceCommand": {
      "type": "string",
      "const": "design-system"
    },
    "priority": {
      "type": "string",
      "enum": ["must", "should", "could"]
    },
    "references": {
      "type": "array",
      "description": "Optional evidence links or file references.",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "metadata": {
      "type": "object",
      "description": "Optional structured details needed during execution.",
      "additionalProperties": {
        "type": ["string", "number", "boolean"]
      },
      "default": {}
    }
  }
}
